# .env로 복사해 채운다 (.env는 gitignore — 시크릿은 여기로만, CLAUDE.md 작업 규칙)
# Google OAuth 클라이언트: GCP 콘솔 → API 및 서비스 → 사용자 인증 정보
#   승인된 리디렉션 URI 2개 등록 필요 (로그인·위임이 콜백을 분리 — §8.5):
#     http://localhost:8080/login/oauth2/code/google
#     http://localhost:8080/authorized/google-tasks
# Google Tasks API도 활성화 필요: API 라이브러리 → Google Tasks API → 사용
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 위임 토큰 암호화 키 (AES-256-GCM) — 생성: openssl rand -base64 32
TOKEN_ENC_KEY=
